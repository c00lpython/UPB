projects/*/*.conf
projects/*/*.vars.json

# Настройки IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Файлы сборки
dist/
build/
*.egg-info/
*.egg

# OS метаданные
.DS_Store
Thumbs.db
desktop.ini

# UPB временные файлы
*.upb.tmp