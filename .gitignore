# Виртуальное окружение
.venv/
venv/
env/
ENV/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Логи и временные файлы
*.log
*.tmp
*.temp

# Проекты пользователей - исключаем только содержимое, но не саму папку
projects/*/built/
projects/*/*.conf
projects/*/*.vars.json
projects/*/profile/     # <--- ПРОФИЛИ ПРОЕКТОВ (куки, сессии)
projects/*/parser/

# НЕ исключаем projects/ целиком, иначе папка не будет в репозитории
# projects/

# Временные профили браузера
temp_profile_*/
temp_profile_*

# Папка profiles (глобальный профиль — устарело, но на всякий случай)
profiles/
profiles_*/

# Настройки IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Файлы сборки
dist/
build/
*.egg-info/
*.egg

# OS метаданные
.DS_Store
Thumbs.db
desktop.ini

# UPB временные файлы
*.upb.tmp

# Логи UPB
upb_*.log