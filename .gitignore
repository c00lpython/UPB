# Создаём новый .gitignore
cat > .gitignore << 'EOF'
# Виртуальное окружение
.venv/
venv/
env/
ENV/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Логи и временные файлы
*.log
*.tmp
*.temp

# ПРОЕКТЫ ПОЛЬЗОВАТЕЛЕЙ - ИСКЛЮЧАЕМ ПОЛНОСТЬЮ
projects/

# Временные профили браузера
temp_profile_*/

# Настройки IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Файлы сборки
dist/
build/
*.egg-info/
*.egg

# OS метаданные
.DS_Store
Thumbs.db
desktop.ini

# UPB временные файлы
*.upb.tmp
licensing.md
# Логи UPB
upb_*.log
EOF